<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tongji.dm.mapper.DmMessageMapper">

    <resultMap id="MsgMap" type="com.tongji.dm.model.DmMessage">
        <id     property="id"       column="id"/>
        <result property="convId"   column="conv_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="body"     column="body"/>
        <result property="sentAt"   column="sent_at"/>
        <result property="readAt"   column="read_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.tongji.dm.model.DmMessage">
        INSERT INTO dm_messages (id, conv_id, sender_id, body)
        VALUES (#{id}, #{convId}, #{senderId}, #{body})
    </insert>

    <select id="listByConv" resultMap="MsgMap">
        SELECT * FROM dm_messages
        WHERE conv_id = #{convId}
        <if test="beforeId != null">
          AND id &lt; #{beforeId}
        </if>
        ORDER BY id DESC
        LIMIT #{size}
    </select>

</mapper>
