# =============================================================================
# YiXiang (颐享) 应用配置（模板）
# 复制为 application.yml 并填入真实值
# =============================================================================

# ---- 数据源 / MySQL ----
spring.datasource:
  url: jdbc:mysql://localhost:3306/zhiguang?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
  username: root
  password: YOUR_MYSQL_PASSWORD
  driver-class-name: com.mysql.cj.jdbc.Driver

# ---- MyBatis ----
mybatis:
  mapper-locations: classpath:mapper/*.xml
  type-aliases-package: com.tongji

# ---- Redis ----
spring.data.redis:
  host: localhost
  port: 6379

# ---- Elasticsearch ----
spring.elasticsearch:
  uris:
    - http://localhost:9200

# ---- Elasticsearch vector store (Spring AI RAG) ----
spring.ai.vectorstore.elasticsearch:
  index-name: zhiguang-ai-index

# ---- Kafka ----
spring.kafka:
  bootstrap-servers: localhost:9092
  producer:
    key-serializer: org.apache.kafka.common.serialization.StringSerializer
    value-serializer: org.apache.kafka.common.serialization.StringSerializer
  consumer:
    key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
    value-deserializer: org.apache.kafka.common.serialization.StringDeserializer
    group-id: zhiguang-consumer
    enable-auto-commit: false

# ---- Canal ----
canal:
  enabled: true
  host: localhost
  port: 11111
  destination: example
  username: ""
  password: ""
  filter: zhiguang\\.outbox
  batchSize: 1000
  intervalMs: 200

# ---- DeepSeek (Spring AI, 对话模型) ----
spring.ai.deepseek:
  api-key: YOUR_DEEPSEEK_API_KEY
  base-url: https://api.deepseek.com
  chat:
    options:
      model: deepseek-v4-flash

# ---- OpenAI (Spring AI, Embedding 向量模型) ----
spring.ai.openai:
  api-key: YOUR_OPENAI_API_KEY
  base-url: https://api.deepseek.com
  embedding:
    options:
      model: text-embedding-ada-002

# ---- 阿里云 OSS ----
oss:
  endpoint: oss-cn-beijing.aliyuncs.com
  access-key-id: YOUR_OSS_ACCESS_KEY_ID
  access-key-secret: YOUR_OSS_ACCESS_KEY_SECRET
  bucket: YOUR_OSS_BUCKET
  public-domain: ""
  folder: posts

# ---- 邮件 (验证码) ----
spring.mail:
  host: smtp.qq.com
  port: 587
  username: YOUR_EMAIL@qq.com
  password: YOUR_EMAIL_SMTP_PASSWORD
  properties:
    mail.smtp.auth: true
    mail.smtp.starttls.enable: true

# ---- 认证 / JWT ----
auth:
  jwt:
    issuer: zhiguang
    key-id: zhiguang-key
    access-token-ttl: 15m
    refresh-token-ttl: 7d
    private-key: classpath:keys/private.pem
    public-key: classpath:keys/public.pem
  verification:
    code-length: 6
    ttl: 5m
    max-attempts: 5
    send-interval: 60s
    daily-limit: 10
  password:
    bcrypt-strength: 12
    min-length: 8

# ---- 缓存 ----
cache:
  l2:
    public-cfg:
      ttl-seconds: 15
      max-size: 1000
    mine-cfg:
      ttl-seconds: 10
      max-size: 1000
    detail-cfg:
      ttl-seconds: 30
      max-size: 5000
  hotkey:
    window-seconds: 60
    segment-seconds: 10
    level-low: 50
    level-medium: 200
    level-high: 500
    extend-low-seconds: 20
    extend-medium-seconds: 60
    extend-high-seconds: 120

# ---- 计数器 ----
counter:
  rebuild:
    lock:
      ttl-ms: 5000
      watchdog-ms: 30000
    rate:
      permits: 3
      window-seconds: 10
    backoff:
      base-ms: 500
      max-ms: 30000

# ---- Actuator ----
management:
  endpoints:
    web:
      exposure:
        include: health,info
